{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Django: Port 9000",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\manage.py",
            "args": [
                "runserver",
                "9000",
                "--noreload"
            ],
            "django": true,
            "autoStartBrowser": false,
            "justMyCode": true,
            "timeout": 60000
        }
    ]
}